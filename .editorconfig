# Kit template — copied to product repo root on /start-setting and sync (if missing).
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,mdc,json,yml,yaml}]
charset = utf-8

[*.{ps1,psm1}]
charset = utf-8

[*.{ts,tsx,js,jsx,css,scss,html,vue,svelte}]
charset = utf-8
