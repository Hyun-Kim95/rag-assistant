# Copy to application-local.yml for machine-specific settings.
# application-local.yml is ignored by git.
#
# === 로컬 실행 체크리스트 ===
# 1) PostgreSQL + pgvector (기본: localhost:15432 / DB rag_assistant)
# 2) Ollama: ollama pull qwen2.5:7b && ollama pull nomic-embed-text
# 3) TEI reranker (rag.rerank-enabled=true 기본 on): bge-reranker-v2-m3 컨테이너 기동
#    - dietManagement docker-compose의 tei-reranker 서비스 사용:  docker compose up -d tei-reranker
#    - 호스트 http://localhost:8085 노출 (app application.yml의 reranker base-url과 일치)
#    - 최초 1회 모델 다운로드 (~수백 MB). 준비 전 호출은 fallback(원본 순서)으로 동작
#    - TEI를 띄우지 않으면: rerank 건너뛰고 원본 RRF/cosine 순서 유지 (RAG는 정상 동작)
# 4) cp application-local.yml.example application-local.yml 후 password 수정
# 5) 일반 앱: gradlew.bat bootRun
# 6) RAG 평가 자동 실행 (Ollama+DB 필요, 앱 기동 후 10문항 1회):
#    .\gradlew.bat bootRun --args="--rag.eval.enabled=true --rag.eval.mode=RAG_ON"
#    .\gradlew.bat bootRun --args="--rag.eval.enabled=true --rag.eval.mode=RAG_OFF"
#    산출물 (eval/reports/ — latest·compare 는 Git 커밋, runs/ 는 gitignore):
#      eval/reports/latest-rag-on.json|.md
#      eval/reports/latest-rag-off.json|.md
#      eval/reports/compare-latest.md   (on·off 둘 다 실행 후)
#      eval/reports/runs/{timestamp}_{MODE}.json|.md  (로컬만)
# 평가는 CLI 플래그로만 켭니다. 아래 yml에 rag.eval 항목을 넣을 필요 없습니다.

spring:
  config:
    activate:
      on-profile: local
  datasource:
    password: your-password

# spring:
#   datasource:
#     url: jdbc:postgresql://localhost:15432/rag_assistant
#     username: rag_assistant

# === Model Router: OpenAI 호환 2nd provider (Groq 무료 티어) ===
# 키가 없으면 enabled=false(기본)로 두면 됩니다. groq는 available()=false 로 라우팅에서 스킵되고
# Ollama 단독으로 동작합니다. 폴백/요청 라우팅을 실제로 보려면 아래 둘을 채우세요.
# - 키 발급: https://console.groq.com → API Keys (gsk_... )
# - api-key 는 절대 application.yml(커밋 대상)에 두지 말 것. 이 파일(gitignore)에만.
# llm:
#   openai-compat:
#     enabled: true
#     api-key: gsk_your_groq_key
